# Supabase (required for database and auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Supabase frontend (required for client-side auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth (required for GSC and Google Ads connections)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI (required for SEO recommendations)
OPENAI_API_KEY=

# Anthropic (required for audits and content generation)
ANTHROPIC_API_KEY=

# Google Ads - Search Volume (optional)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=

# LTX Video (optional fallback for social video generation)
LTX_API_KEY=

# Google Gemini / VEO 3 (required for AI video ad generation and image generation)
GEMINI_API_KEY=

# fal.ai (required for FLUX, Kling, LTX, image editing, and more)
FAL_API_KEY=

# Stripe (future - for plan billing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
